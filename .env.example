# =============================================================================
# Relationship Mapper — Environment Variables
# =============================================================================
# Copy this file to .env (or .env.local) and fill in the values.
# NEVER commit .env or .env.local — they are gitignored.
#
# In production these values live in Vercel project settings.
# Get production values from: `vercel env pull` or the Vercel dashboard.
# =============================================================================

# --- Database (PostgreSQL via Neon) -----------------------------------------
# Get these from your Neon dashboard at https://neon.tech
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
DIRECT_URL="postgresql://user:password@host/database?sslmode=require"

# --- NextAuth.js ------------------------------------------------------------
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=""
AUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
# Public URL of the app (used for Stripe redirects when NEXTAUTH_URL isn't set)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Admin seed (optional) --------------------------------------------------
# Used only by `npm run db:seed`. If ADMIN_PASSWORD is blank, one is generated.
ADMIN_EMAIL="admin@jcrb.org"
ADMIN_PASSWORD=""

# --- Stripe (fundraiser payments) -------------------------------------------
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
STRIPE_CLIENT_ID=""
STRIPE_WEBHOOK_SECRET=""

# --- QuickBooks (donation sync) ---------------------------------------------
# Developer portal: https://developer.intuit.com
QB_ENVIRONMENT="sandbox"  # "sandbox" or "production"
QB_CLIENT_ID=""
QB_CLIENT_SECRET=""
QB_REDIRECT_URI="http://localhost:3000/api/quickbooks/callback"

# --- Constant Contact (email marketing) -------------------------------------
# App portal: https://app.constantcontact.com
CONSTANT_CONTACT_API_KEY=""
CONSTANT_CONTACT_SECRET=""
CONSTANT_CONTACT_REDIRECT_URI="http://localhost:3000/api/constant-contact/callback"
