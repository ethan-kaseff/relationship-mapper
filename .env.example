# Database (PostgreSQL with Neon)
# Get these from your Neon dashboard at https://neon.tech
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
DIRECT_URL="postgresql://user:password@host/database?sslmode=require"

# For local SQLite development (optional, switch provider in schema.prisma)
# DATABASE_URL="file:./dev.db"

# NextAuth.js
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Admin credentials for seeding (optional)
# If not set, defaults to admin@jcrb.org with a generated password
ADMIN_EMAIL="admin@jcrb.org"
ADMIN_PASSWORD=""
