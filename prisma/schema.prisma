generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Office ──────────────────────────────────────────────────────────────────

model Office {
  id       String    @id @default(uuid())
  name     String    @unique
  isSiloed Boolean   @default(false) @map("is_siloed")
  users              User[]
  people             People[]
  partners           Partner[]
  events             Event[]
  fundraisers        Fundraiser[]
  annualEventTypes   AnnualEventType[]
  integrationTokens  IntegrationToken[]

  @@map("office")
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id        String  @id @default(uuid())
  email     String  @unique
  password  String
  firstName String  @map("first_name")
  lastName  String  @map("last_name")
  role      String  @default("OFFICE_ADMIN") // "SYSTEM_ADMIN", "OFFICE_ADMIN", "OFFICE_USER", "VIEWER", or "CONNECTOR"
  officeId  String  @map("office_id")
  office    Office  @relation(fields: [officeId], references: [id])
  events    Event[] @relation("EventCreator")

  @@index([officeId])
  @@map("user")
}

// ─── Lookup Tables ───────────────────────────────────────────────────────────

model OrganizationType {
  id       String    @id @default(uuid())
  typeName String    @unique @map("type_name")
  partners Partner[]

  @@map("organization_type")
}

model RelationshipType {
  id               String         @id @default(uuid())
  relationshipDesc String         @map("relationship_desc")
  notes            String?
  relationships    Relationship[]

  @@map("relationship_type")
}

model AnnualEventType {
  id       String @id @default(uuid())
  name     String
  officeId String @map("office_id")
  office   Office @relation(fields: [officeId], references: [id])

  peopleAnnualEventTypes      PeopleAnnualEventType[]
  partnerAnnualEventTypes     PartnerAnnualEventType[]
  partnerRoleAnnualEventTypes PartnerRoleAnnualEventType[]

  @@unique([name, officeId])
  @@index([officeId])
  @@map("annual_event_type")
}

// ─── Core Tables ─────────────────────────────────────────────────────────────

model People {
  id            String   @id @default(uuid())
  firstName      String   @map("first_name")
  middleInitial  String?  @map("middle_initial")
  lastName       String   @map("last_name")
  prefix         String?  @map("prefix")
  greeting       String?  @map("greeting")
  address       String?
  city          String?
  state         String?
  zip           String?
  phoneNumber   String?  @map("phone_number")
  email1         String?  @map("email_1")
  email2         String?  @map("email_2")
  isConnector    Boolean  @default(false) @map("is_connector")
  connectorToken String?  @unique @map("connector_token")
  ccContactId1   String?  @map("cc_contact_id_1")
  ccContactId2   String?  @map("cc_contact_id_2")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  officeId      String   @map("office_id")
  office        Office   @relation(fields: [officeId], references: [id])

  partnerRoles            PartnerRole[]
  roleAssignments         RoleAssignment[]
  relationships           Relationship[]  @relation("ConnectorRelationships")
  targetOfRelationships   Relationship[]  @relation("TargetRelationships")
  connections             Connection[]
  happeningResponses HappeningResponse[]
  eventInvites       EventInvite[]
  annualEventTypes   PeopleAnnualEventType[]
  donations          Donation[]

  @@unique([prefix, firstName, middleInitial, lastName, officeId], map: "people_name_office_unique")
  @@index([officeId])
  @@map("people")
}

model Partner {
  id                 String            @id @default(uuid())
  orgPeopleFlag      String            @map("org_people_flag") // "O" or "P"
  organizationName   String?           @map("organization_name")
  organizationTypeId String?           @map("organization_type_id")
  organizationType   OrganizationType? @relation(fields: [organizationTypeId], references: [id])
  address            String?
  city               String?
  state              String?
  zip                String?
  phoneNumber        String?           @map("phone_number")
  email              String?
  website            String?
  priority           Int               @default(5)
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  officeId           String            @map("office_id")
  office             Office            @relation(fields: [officeId], references: [id])

  partnerRoles       PartnerRole[]
  annualEventTypes   PartnerAnnualEventType[]

  @@index([officeId])
  @@map("partner")
}

model PartnerRole {
  id              String  @id @default(uuid())
  partnerId       String  @map("partner_id")
  partner         Partner @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  roleDescription String  @map("role_description")
  peopleId        String? @map("people_id")
  person          People? @relation(fields: [peopleId], references: [id])
  roleAssignments  RoleAssignment[]
  relationships    Relationship[]
  connections      Connection[]
  annualEventTypes PartnerRoleAnnualEventType[]

  @@map("partner_role")
}

model Relationship {
  id                 String           @id @default(uuid())
  peopleId           String           @map("people_id")
  person             People           @relation("ConnectorRelationships", fields: [peopleId], references: [id])
  targetPersonId     String           @map("target_person_id")
  targetPerson       People           @relation("TargetRelationships", fields: [targetPersonId], references: [id])
  partnerRoleId      String?          @map("partner_role_id")
  partnerRole        PartnerRole?     @relation(fields: [partnerRoleId], references: [id], onDelete: SetNull)
  relationshipTypeId String           @map("relationship_type_id")
  relationshipType   RelationshipType @relation(fields: [relationshipTypeId], references: [id])
  lastReviewedDate   DateTime?        @map("last_reviewed_date")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")

  @@unique([peopleId, targetPersonId])
  @@map("relationship")
}

model Connection {
  id             String      @id @default(uuid())
  peopleId       String      @map("people_id")
  person         People      @relation(fields: [peopleId], references: [id])
  partnerRoleId  String      @map("partner_role_id")
  partnerRole    PartnerRole @relation(fields: [partnerRoleId], references: [id], onDelete: Cascade)
  connectionDate DateTime    @map("connection_date")
  connectionTime String?     @map("connection_time")
  notes          String?
  createdAt      DateTime    @default(now()) @map("created_at")

  @@map("connection")
}

model Happening {
  id                   String              @id @default(uuid())
  happeningDate        DateTime            @map("happening_date")
  happeningTime        String?             @map("happening_time")
  happeningDescription String              @map("happening_description")
  createdAt            DateTime            @default(now()) @map("created_at")

  responses HappeningResponse[]

  @@map("happening")
}

model HappeningResponse {
  id            String    @id @default(uuid())
  peopleId      String    @map("people_id")
  person        People    @relation(fields: [peopleId], references: [id])
  happeningId   String    @map("happening_id")
  happening     Happening @relation(fields: [happeningId], references: [id], onDelete: Cascade)
  responseDate  DateTime? @map("response_date")
  responseTime  String?   @map("response_time")
  responseNotes String?   @map("response_notes")
  isPublic      Boolean   @default(true) @map("is_public")
  platform      String?   @map("platform")
  platformLink  String?   @map("platform_link")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("happening_response")
}

model RoleAssignment {
  id            String      @id @default(uuid())
  partnerRoleId String      @map("partner_role_id")
  partnerRole   PartnerRole @relation(fields: [partnerRoleId], references: [id], onDelete: Cascade)
  peopleId      String      @map("people_id")
  person        People      @relation(fields: [peopleId], references: [id])
  startDate     DateTime?   @map("start_date")
  endDate       DateTime?   @map("end_date")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("role_assignment")
}

// ─── Events & Seating ──────────────────────────────────────────────────────────

model Event {
  id              String        @id @default(uuid())
  title           String
  description     String?
  eventDate       DateTime?     @map("event_date")
  eventTime       String?       @map("event_time")
  location        String?
  trackSeating    Boolean       @default(true) @map("track_seating")
  trackMeals      Boolean       @default(true) @map("track_meals")
  seatingLayout   Json?         @map("seating_layout")
  ticketPrice     Int?          @map("ticket_price")
  mealCost        Int?          @map("meal_cost")
  stripeProductId String?       @map("stripe_product_id")
  ccListId        String?       @map("cc_list_id")
  ccSyncCount     Int           @default(0) @map("cc_sync_count")
  createdById     String        @map("created_by_id")
  createdBy       User          @relation("EventCreator", fields: [createdById], references: [id])
  officeId        String        @map("office_id")
  office          Office        @relation(fields: [officeId], references: [id])
  invites         EventInvite[]
  fundraisers     Fundraiser[]
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  @@index([officeId])
  @@map("event")
}

model EventInvite {
  id           String    @id @default(uuid())
  eventId      String    @map("event_id")
  event        Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  peopleId     String    @map("people_id")
  person       People    @relation(fields: [peopleId], references: [id])
  rsvpStatus   String    @default("PENDING") @map("rsvp_status") // PENDING, YES, NO, MAYBE
  rsvpDate     DateTime? @map("rsvp_date")
  meal         String    @default("Standard")
  dietary      Json      @default("[]")
  notes        String?
  group        String    @default("")
  tableId      String?   @map("table_id")
  seatIndex    Int?      @map("seat_index")
  taxDeductibleOverride Int? @map("tax_deductible_override")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@unique([eventId, peopleId])
  @@index([eventId])
  @@map("event_invite")
}

// ─── Annual Event Type Join Tables ────────────────────────────────────────────

model PeopleAnnualEventType {
  id                 String          @id @default(uuid())
  peopleId           String          @map("people_id")
  person             People          @relation(fields: [peopleId], references: [id], onDelete: Cascade)
  annualEventTypeId  String          @map("annual_event_type_id")
  annualEventType    AnnualEventType @relation(fields: [annualEventTypeId], references: [id], onDelete: Cascade)

  @@unique([peopleId, annualEventTypeId])
  @@map("people_annual_event_type")
}

model PartnerAnnualEventType {
  id                 String          @id @default(uuid())
  partnerId          String          @map("partner_id")
  partner            Partner         @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  annualEventTypeId  String          @map("annual_event_type_id")
  annualEventType    AnnualEventType @relation(fields: [annualEventTypeId], references: [id], onDelete: Cascade)

  @@unique([partnerId, annualEventTypeId])
  @@map("partner_annual_event_type")
}

model PartnerRoleAnnualEventType {
  id                 String          @id @default(uuid())
  partnerRoleId      String          @map("partner_role_id")
  partnerRole        PartnerRole     @relation(fields: [partnerRoleId], references: [id], onDelete: Cascade)
  annualEventTypeId  String          @map("annual_event_type_id")
  annualEventType    AnnualEventType @relation(fields: [annualEventTypeId], references: [id], onDelete: Cascade)

  @@unique([partnerRoleId, annualEventTypeId])
  @@map("partner_role_annual_event_type")
}

// ─── Integrations ─────────────────────────────────────────────────────────────

model IntegrationToken {
  id                String   @id @default(uuid())
  officeId          String   @map("office_id")
  office            Office   @relation(fields: [officeId], references: [id], onDelete: Cascade)
  provider          String   @default("constant_contact")
  providerAccountId String?  @map("provider_account_id")
  accessToken       String   @map("access_token")
  refreshToken      String   @map("refresh_token")
  expiresAt         DateTime @map("expires_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([officeId, provider])
  @@index([officeId])
  @@map("integration_token")
}

// ─── Fundraising ──────────────────────────────────────────────────────────────

model Fundraiser {
  id              String     @id @default(uuid())
  title           String
  description     String?
  goalAmount      Int        @map("goal_amount")
  currentAmount   Int        @default(0) @map("current_amount")
  presetAmounts   Json       @default("[2500, 5000, 10000]") @map("preset_amounts")
  slug            String     @unique
  startDate       DateTime?  @map("start_date")
  endDate         DateTime?  @map("end_date")
  isActive        Boolean    @default(true) @map("is_active")
  stripeProductId String?    @map("stripe_product_id")
  eventId         String?    @map("event_id")
  event           Event?     @relation(fields: [eventId], references: [id], onDelete: SetNull)
  officeId        String     @map("office_id")
  office          Office     @relation(fields: [officeId], references: [id])
  donations       Donation[]
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  @@index([officeId])
  @@index([slug])
  @@map("fundraiser")
}

model Donation {
  id                String     @id @default(uuid())
  fundraiserId      String     @map("fundraiser_id")
  fundraiser        Fundraiser @relation(fields: [fundraiserId], references: [id], onDelete: Cascade)
  amount            Int
  donorName         String?    @map("donor_name")
  donorEmail        String?    @map("donor_email")
  peopleId          String?    @map("people_id")
  person            People?    @relation(fields: [peopleId], references: [id], onDelete: SetNull)
  isAnonymous       Boolean    @default(false) @map("is_anonymous")
  paymentMethod     String     @default("stripe") @map("payment_method")
  stripePaymentId   String?    @unique @map("stripe_payment_id")
  stripeSubId       String?    @map("stripe_sub_id")
  isRecurring       Boolean    @default(false) @map("is_recurring")
  recurringInterval String?    @map("recurring_interval")
  tributeType       String?    @map("tribute_type")
  tributeName       String?    @map("tribute_name")
  isTaxDeductible   Boolean    @default(true) @map("is_tax_deductible")
  taxDeductibleAmount Int?     @map("tax_deductible_amount")
  notes             String?
  approvalStatus    String     @default("AUTO_APPROVED") @map("approval_status")
  qbSyncStatus      String     @default("NOT_SYNCED") @map("qb_sync_status")
  qbReceiptId       String?    @map("qb_receipt_id")
  donatedAt         DateTime   @default(now()) @map("donated_at")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  @@index([fundraiserId])
  @@index([peopleId])
  @@index([approvalStatus])
  @@map("donation")
}
